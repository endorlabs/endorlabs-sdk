{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/endorlabs/endorlabs-sdk/agent-skills/schema/workflows.schema.json",
  "title": "Supplemental agent-skills/workflows.yaml",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflows"],
  "properties": {
    "workflows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflow_row"
      }
    }
  },
  "$defs": {
    "workflow_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "module"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9-]+$"
        },
        "cli": {
          "type": ["string", "null"]
        },
        "module": {
          "type": "string",
          "minLength": 1
        },
        "skill": {
          "type": ["string", "null"]
        },
        "default_output": {
          "type": ["string", "null"]
        },
        "agent_visible": {
          "type": "boolean",
          "default": true
        },
        "composition": {
          "type": "string",
          "enum": ["artifact_chain", "library_api", "cli_only"]
        },
        "library_entrypoints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    }
  }
}
