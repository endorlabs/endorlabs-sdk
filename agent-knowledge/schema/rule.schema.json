{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/endorlabs/endorlabs-sdk/agent-knowledge/schema/rule.schema.json",
  "title": "Agent rule frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "tags", "summary"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9-]+$"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    }
  }
}
