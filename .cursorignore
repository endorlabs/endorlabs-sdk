# Override .gitignore — let Cursor AI see these gitignored directories.
# .gitignore keeps them out of version control; ! negations here let Cursor index them.

# API spec + user docs (context bootstrap)
!.endorlabs-context/
!.endorlabs-context/**
!.endorlabs-context/docs/
!.endorlabs-context/docs/**
!.endorlabs-context/openapiv2.swagger.json
!.endorlabs-context/session-*

# Research files, responses
!.tmp/
!.tmp/**

# Generated files
!.generated/
!.generated/**
