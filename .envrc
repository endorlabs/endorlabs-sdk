# direnv configuration for Endor Cockpit
# Install direnv: https://direnv.net/docs/installation.html
# Then run: direnv allow

# Activate UV virtual environment
if command -v uv >/dev/null 2>&1; then
  # Use UV to manage the virtual environment
  eval "$(uv run --env)"
else
  # Fallback to manual activation if UV is not available
  if [ -f ".venv/bin/activate" ]; then
    source .venv/bin/activate
  elif [ -f ".venv/Scripts/activate" ]; then
    source .venv/Scripts/activate
  fi
fi

# Set environment variables for development
export UV_SYSTEM_PYTHON=0
export PYTHONPATH="${PWD}/src:${PYTHONPATH}"

# Configure uv to automatically load .env file (uv convention)
export UV_ENV_FILE=.env

# Load .env file if it exists (for direnv, uv will also load it automatically)
if [ -f .env ]; then
  # Source .env file to set variables in current shell
  set -a
  source .env
  set +a
fi

# Credentials/tokens: set by you in .env or environment (see README).

# endorctl scan: use UV for Python dependency resolution (repo uses uv; set in .env to override)
export ENDOR_SCAN_ENABLE_UV_PACKAGE_MANAGER=true

# Optional: Set development-specific environment variables
# export ENDOR_NAMESPACE="your-namespace"
