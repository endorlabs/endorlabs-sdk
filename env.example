# Endor Labs API Configuration
# Copy this file to .env and fill in your actual values

# REQUIRED: Endor Labs API Configuration
ENDOR_API=https://api.endorlabs.com
ENDOR_API_CREDENTIALS_KEY=your-api-key-here
ENDOR_API_CREDENTIALS_SECRET=your-api-secret-here

# OPTIONAL: Namespace for operations (defaults to tenant namespace)
ENDOR_NAMESPACE=your-tenant-namespace

# OPTIONAL: Agent ID for testing and identification
AGENT_ID=integration-test-agent

# OPTIONAL: OpenAI API Key for RAG functionality
# Required for vector database initialization and semantic search
OPENAI_API_KEY=your-openai-api-key-here

# Development vs Runtime Dependencies:
# - Core functionality: ENDOR_API, ENDOR_API_CREDENTIALS_KEY, ENDOR_API_CREDENTIALS_SECRET
# - RAG functionality: OPENAI_API_KEY (install with: uv pip install -e ".[rag]")
# - Testing: All above variables
# - Operations: ENDOR_NAMESPACE for specific namespace operations
